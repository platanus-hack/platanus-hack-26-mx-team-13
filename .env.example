# ─────────────────────────────────────────────────────────────
# Facturín — environment variables (copy to .env.local and fill)
# ─────────────────────────────────────────────────────────────

# ── Database (Block 1) ────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=

# ── Auth / NextAuth v5 (Block 1) ──────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Optional in local; in prod = https://your-deploy.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com (OAuth client)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_ID=
GOOGLE_SECRET=

# Resend — magic-link login (optional)
RESEND_API_KEY=

# ── AI (Claude Haiku — parse OCR text → structured ticket JSON) ──
ANTHROPIC_API_KEY=

# ── Ticket OCR: Google Cloud Vision (P0) ──────────────────────
# A Cloud Vision API key (Console → APIs & Services → Credentials → API key).
# Enable the Cloud Vision API on the project. Used via REST (images:annotate).
GOOGLE_VISION_API_KEY=

# ── Engine browser: Browserbase (cloud browser via Stagehand) ──
# Browsers can't run on Vercel — the invoicing engine drives a cloud browser on
# Browserbase. Dashboard → Settings for the API key and project id. keepAlive
# sessions (used so a human can take over) require a paid plan.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Local dev only: set to "true" to launch a headed LOCAL browser instead of
# Browserbase (no cloud session). Leave empty in production.
ENGINE_LOCAL_BROWSER=

# ── Engine: Trigger.dev (durable runtime for the invoicing task) ──
# Secret key authenticates the SDK (dashboard → Project → API keys). Required at
# runtime to enqueue `process-invoice` and at deploy time (trigger.dev deploy).
TRIGGER_SECRET_KEY=
# Project ref (dashboard → Project → Settings). Read by trigger.config.js; can
# also be hardcoded there instead of set here.
TRIGGER_PROJECT_REF=

# ── Storage: Cloudflare R2 (Block 1, S3-compatible) ───────────
# R2 dashboard → Manage API Tokens. Endpoint = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=facturin
# Public base URL of the bucket (r2.dev or custom domain) — optional if reading server-side by key
R2_PUBLIC_URL=
