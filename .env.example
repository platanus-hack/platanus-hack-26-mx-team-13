# ─────────────────────────────────────────────────────────────
# Facturín — environment variables (copy to .env.local and fill)
# ─────────────────────────────────────────────────────────────

# ── Database (Block 1) ────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=

# ── Auth / NextAuth v5 (Block 1) ──────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Optional in local; in prod = https://your-deploy.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com (OAuth client)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_ID=
GOOGLE_SECRET=

# Resend — transactional + inbound CFDI delivery
# Sends invoice-delivery mail AND reads received emails/attachments (Attachments API).
RESEND_API_KEY=
# Svix signing secret for the inbound webhook (Resend dashboard → Webhooks).
# Required in any deployed env; if unset locally, signature checks are skipped.
RESEND_WEBHOOK_SECRET=
# Catch-all subdomain that receives merchant-mailed CFDIs as <ticketId>@<domain>.
# Needs an MX record pointing at Resend. Defaults to config.resend.receivingDomain.
RESEND_RECEIVING_DOMAIN=facturas.facturin.mx

# ── AI (Claude) ───────────────────────────────────────────────
# Powers BOTH the OCR text→JSON parse AND the engine browser agent (Stagehand's
# act/observe/extract + the reach_form operator). The "anthropic/" engine model
# auto-loads this key.
ANTHROPIC_API_KEY=
# Optional: override the Stagehand fill/observe model (default anthropic/claude-haiku-4-5).
# Use anthropic/claude-sonnet-4-6 for higher-fidelity field extraction on tricky portals.
ENGINE_LLM_MODEL=

# ── Ticket OCR: Google Cloud Vision (P0) ──────────────────────
# A Cloud Vision API key (Console → APIs & Services → Credentials → API key).
# Enable the Cloud Vision API on the project. Used via REST (images:annotate).
GOOGLE_VISION_API_KEY=

# ── Engine: portal discovery (Firecrawl web search) ──────────
# The resolve_portal node maps a merchant's RFC → its CFDI portal URL. Known
# merchants resolve instantly from the KnownMerchant registry; an unknown RFC is
# discovered once via a Firecrawl web search and then persisted. Get a key at
# https://firecrawl.dev (dashboard → API keys).
FIRECRAWL_API_KEY=

# ── Engine browser: Browserbase (cloud browser via Stagehand) ──
# Browsers can't run on Vercel — the invoicing engine drives a cloud browser on
# Browserbase. Dashboard → Settings for the API key and project id. keepAlive
# sessions (used so a human can take over) require a paid plan.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Local dev only: set to "true" to launch a headed LOCAL browser instead of
# Browserbase (no cloud session). Leave empty in production.
ENGINE_LOCAL_BROWSER=

# ── Engine: Trigger.dev (durable runtime for the invoicing task) ──
# Secret key authenticates the SDK (dashboard → Project → API keys). Required at
# runtime to enqueue `process-invoice` and at deploy time (trigger.dev deploy).
TRIGGER_SECRET_KEY=
# Project ref (dashboard → Project → Settings). Read by trigger.config.js; can
# also be hardcoded there instead of set here.
TRIGGER_PROJECT_REF=

# ── Storage: Cloudflare R2 (Block 1, S3-compatible) ───────────
# R2 dashboard → Manage API Tokens. Endpoint = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=facturin
# Public base URL of the bucket (r2.dev or custom domain) — optional if reading server-side by key
R2_PUBLIC_URL=
